# Server
PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET=change-this-to-a-random-string-in-production
JWT_EXPIRES_IN=7d

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/onlyai

# AI API
AI_API_KEY=your-deepseek-or-openai-api-key
AI_MODEL=qwen-turbo
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Stripe (Payment Processing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Get these from Stripe Dashboard > Products > Create Product/Price
# STRIPE_PRICE_STANDARD=price_xxxxx
# STRIPE_PRICE_PREMIUM=price_xxxxx
# STRIPE_PRICE_VIP=price_xxxxx

# Stripe Publishable Key (for frontend Stripe.js)
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# Payment endpoints
FRONTEND_URL=

# Admin
ADMIN_API_KEY=onlyai-admin-key-2026
ADMIN_EMAILS=

# CORS
CORS_ORIGIN=https://songhe9527zzz.github.io,http://localhost:3000
